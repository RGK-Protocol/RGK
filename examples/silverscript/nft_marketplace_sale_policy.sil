pragma silverscript ^0.1.0;

contract RGKNftMarketplaceSalePolicy() {
    int price_amount = 120000;
    int royalty_amount = 12000;
    byte[32] asset_id = 0x8181818181818181818181818181818181818181818181818181818181818181;
    byte[32] lane_id = 0x2222222222222222222222222222222222222222222222222222222222222222;
    byte[32] metadata_commitment = 0xa3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3a3;
    byte[32] royalty_policy_commitment = 0xa4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4a4;
    byte[32] owner_commitment = 0xb1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1;
    byte[32] seller_owner_commitment = 0xb1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1b1;
    byte[32] buyer_owner_commitment = 0xc2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2c2;
    byte[32] payment_asset_id = 0xf6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6f6;
    byte[32] sale_commitment = 0xf8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8f8;
    byte[32] authorization_commitment = 0xf3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3;
    byte[32] ownership_authorization_commitment = 0xf3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3;
    byte[32] state_digest = 0xe4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4e4;

    #[covenant.singleton(mode = verification)]
    function settle_sale(
        State prev_state,
        State new_state,
        byte[32] seller,
        byte[32] buyer,
        byte[32] payment_asset,
        int paid_amount,
        int royalty_paid,
        byte[32] royalty_policy,
        byte[32] authorization,
        byte[32] sale_proof
    ) {
        require(prev_state.asset_id == asset_id);
        require(new_state.asset_id == asset_id);
        require(prev_state.lane_id == lane_id);
        require(new_state.lane_id == lane_id);
        require(prev_state.metadata_commitment == metadata_commitment);
        require(new_state.metadata_commitment == metadata_commitment);
        require(prev_state.owner_commitment == seller_owner_commitment);
        require(new_state.owner_commitment == buyer_owner_commitment);
        require(seller == seller_owner_commitment);
        require(buyer == buyer_owner_commitment);
        require(seller != buyer);
        require(payment_asset == payment_asset_id);
        require(paid_amount == price_amount);
        require(royalty_paid == royalty_amount);
        require(royalty_paid <= paid_amount);
        require(royalty_policy == royalty_policy_commitment);
        require(authorization == authorization_commitment);
        require(new_state.ownership_authorization_commitment == authorization);
        require(sale_proof == sale_commitment);
        require(prev_state.state_digest != new_state.state_digest);
    }
}
